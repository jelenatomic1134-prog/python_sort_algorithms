7.1)JDBC 
private Connection connection;

    @Autowired
    public KnjigaJdbcRepository(Connection connection) {
        this.connection = connection;
    }
    
    @Override
    public void save(Knjiga knjiga) {
        String query = "INSERT INTO knjiga (naziv, godina, brojStrana, izdavac, kategorija) VALUES (?,?,?,?,?)";
        PreparedStatement ps;
        try {
            ps = connection.prepareStatement(query);
            ps.setString(1, knjiga.getNaziv());
            ps.setInt(2, knjiga.getGodina());
            ps.setInt(3, knjiga.getBrojStrana());
            ps.setLong(4, knjiga.getIzdavac().getId());
            ps.setLong(5, knjiga.getKategorija().getId());
            ps.executeUpdate();
        } catch (SQLException ex) {
            Logger.getLogger(KnjigaJdbcRepository.class.getName()).log(Level.SEVERE, null, ex);
        }
        
    }

7.2)JPA
private final EntityManagerFactory emf;

    @Autowired
    public KnjigaJpaRepository(@Qualifier(value = "emf")EntityManagerFactory emf) {
        this.emf = emf;
    }

    @Override
    public void save(Knjiga knjiga) {
        EntityManager em = emf.createEntityManager();
        em.getTransaction().begin();
        em.merge(knjiga);
        em.getTransaction().commit();
        em.close();
    }
7.3)Spring
private final JdbcTemplate jdbcTemplate;

    @Autowired
    public KnjigaSpringRepository(JdbcTemplate jdbcTemplate) {
        this.jdbcTemplate = jdbcTemplate;
    }

    @Override
    public void save(Knjiga knjiga) {
        jdbcTemplate.update("INSERT INTO knjiga (naziv, godina, brojStrana, izdavac, kategorija) VALUES (?,?,?,?,?)", knjiga.getNaziv(), knjiga.getGodina(), knjiga.getBrojStrana(),knjiga.getIzdavac().getId(), knjiga.getKategorija().getId());
    }
